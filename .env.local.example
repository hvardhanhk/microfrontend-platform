# ──────────────────────────────────────────────────────────────────────────────
# Multi-Zone environment variables
#
# Copy this file to .env.local in the app that needs it, or set these in the
# Vercel project settings for each deployment.
# ──────────────────────────────────────────────────────────────────────────────

# ── apps/host-shell ───────────────────────────────────────────────────────────
# URLs of the deployed MFE zones.  The host-shell rewrites /products, /cart,
# /dashboard to these origins.
#
# Local dev: leave unset — defaults in next.config.ts point at localhost ports.
# Staging / Production: set to the deployed Vercel URLs.
#
# NEXT_PUBLIC_MFE_PRODUCTS_URL=https://mfe-products-<team>.vercel.app
# NEXT_PUBLIC_MFE_CART_URL=https://mfe-cart-<team>.vercel.app
# NEXT_PUBLIC_MFE_USER_URL=https://mfe-user-<team>.vercel.app

# ── apps/mfe-products  /  apps/mfe-cart  /  apps/mfe-user ────────────────────
# When the host-shell proxies requests to an MFE zone, Next.js generates
# /_next/static/... asset URLs in the HTML.  Without assetPrefix the browser
# resolves these against the host origin and gets 404s.
# Set this to the MFE's own Vercel URL so assets are fetched from the right
# deployment.
#
# Local dev: leave unset — defaults in each next.config.ts use localhost ports.
# Production: set in each MFE's Vercel project environment variables.
#
# NEXT_PUBLIC_ASSET_PREFIX=https://mfe-products-<team>.vercel.app  # in mfe-products
# NEXT_PUBLIC_ASSET_PREFIX=https://mfe-cart-<team>.vercel.app      # in mfe-cart
# NEXT_PUBLIC_ASSET_PREFIX=https://mfe-user-<team>.vercel.app      # in mfe-user

# ── All MFE zones ─────────────────────────────────────────────────────────────
# The /api/auth/* endpoints and /login live on the host-shell.  MFE components
# call these for auth checks and logout.  In production this is the canonical
# domain (same as the rewrite proxy host) so it can be left empty.
# In isolated local dev (running an MFE standalone without the host proxy):
#
# NEXT_PUBLIC_HOST_URL=http://localhost:3000
